{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.MP-Tool/komodo-mcp-server",
  "title": "Komodo MCP Server",
  "description": "MCP server for Komodo - manage Docker containers, servers, stacks, and deployments via AI",
  "websiteUrl": "https://github.com/MP-Tool/komodo-mcp-server",
  "repository": {
    "url": "https://github.com/MP-Tool/komodo-mcp-server",
    "source": "github",
    "id": "1082088566"
  },
  "version": "1.3.2",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "komodo-mcp-server",
      "version": "1.3.2",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "KOMODO_URL",
          "description": "Komodo Core API URL",
          "placeholder": "https://komodo.example.com",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "KOMODO_API_KEY",
          "description": "API key for key-based authentication (recommended)",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "KOMODO_API_SECRET",
          "description": "API secret for key-based authentication (recommended)",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "KOMODO_USERNAME",
          "description": "Username for login authentication (alternative to API key)",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "KOMODO_PASSWORD",
          "description": "Password for login authentication (alternative to API key)",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "KOMODO_JWT_TOKEN",
          "description": "Pre-existing JWT token from browser OAuth login (alternative to API key)",
          "isRequired": false,
          "isSecret": true
        }
      ]
    },
    {
      "registryType": "oci",
      "registryBaseUrl": "https://ghcr.io",
      "identifier": "ghcr.io/mp-tool/komodo-mcp-server:1.3.2",
      "version": "1.3.2",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "KOMODO_URL",
          "description": "Komodo Core API URL",
          "placeholder": "https://komodo.example.com",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "KOMODO_API_KEY",
          "description": "API key for key-based authentication (recommended)",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "KOMODO_API_SECRET",
          "description": "API secret for key-based authentication (recommended)",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "KOMODO_USERNAME",
          "description": "Username for login authentication (alternative to API key)",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "KOMODO_PASSWORD",
          "description": "Password for login authentication (alternative to API key)",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "KOMODO_JWT_TOKEN",
          "description": "Pre-existing JWT token from browser OAuth login (alternative to API key)",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ]
}
