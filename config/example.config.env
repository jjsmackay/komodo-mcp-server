###############################################
# 🦎 KOMODO MCP SERVER — ENVIRONMENT CONFIG 🦎 #
###############################################

## This is the official reference for all environment variables
## supported by the Komodo MCP Server.
##
## Copy this file to .env and adjust the values for your deployment.
##
## All fields with a "Default" provided are optional. If left out,
## the default value is used.
##
## Priority (highest wins):
##   process.env → Config File → .env file → Defaults
##
## You can also use a config file (TOML, YAML, JSON) for non-secret settings.
## See config/config.reference.toml for the full config file reference.
## Auto-discovery filenames: config.toml, config.yaml, config.yml, config.json
## Explicit path: MCP_CONFIG_FILE_PATH=/path/to/config.toml


########################
# KOMODO CONNECTION    #
########################

## Komodo Core server URL.
## Examples:
##   - Local:  https://localhost:9120 or https://127.0.0.1:9120
##   - Remote: https://komodo.example.com:9120
##   - Docker: https://host.docker.internal:9120
## Required for API connectivity.
KOMODO_URL=https://komodo.example.com:9120

## API Key authentication (recommended).
## Obtain these from your Komodo server configuration.
KOMODO_API_KEY=api-key
KOMODO_API_KEY_FILE=/run/secrets/komodo_api_key
KOMODO_API_SECRET=api-secret
KOMODO_API_SECRET_FILE=/run/secrets/komodo_api_secret

## JWT authentication (alternative).
## Pre-existing JWT token obtained from Komodo browser login.
## Extract from browser: JSON.parse(localStorage.getItem("komodo-auth-tokens-v1")).tokens[0].jwt
## Note: JWTs expire (default 1 day). For persistent auth, prefer API key.
KOMODO_JWT_TOKEN=jwt-token
KOMODO_JWT_TOKEN_FILE=/run/secrets/komodo_jwt_token

## Username/password authentication (alternative).
## Create a dedicated user in Komodo for the MCP server.
## Recommended: Use a dedicated user with limited permissions.
KOMODO_USERNAME=mcp-user
KOMODO_USERNAME_FILE=/run/secrets/komodo_username
KOMODO_PASSWORD=password
KOMODO_PASSWORD_FILE=/run/secrets/komodo_password

## API request timeout.
## Accepts human-readable durations (e.g. '30s', '1m', '2m') or plain millisecond counts.
## Default: "30s" (30000ms)
API_TIMEOUT_MS=30s

## Secret redaction (best-effort) of API responses.
## When enabled, secret-looking env values in deployment_info and
## container_inspect responses are replaced with "[redacted]" before reaching
## the MCP client. Heuristic, not a guarantee.
## Default: true
KOMODO_SECRET_SCRUB_ENABLED=true

## Override the built-in secret keyword tokens (comma-separated, matched against
## `_`-delimited key tokens, case-insensitive).
## Built-in default: KEY,SECRET,PASS,PASSWORD,PWD,TOKEN,CREDENTIAL,CREDENTIALS,AUTH,PRIVATE
# KOMODO_SECRET_SCRUB_KEYWORDS=KEY,SECRET,PASSWORD,TOKEN

## Explicit key names to always redact even when they contain no keyword token
## (e.g. DATABASE_URL, SESSION_ID). Comma-separated, case-insensitive.
# KOMODO_SECRET_SCRUB_KEYS=DATABASE_URL,SESSION_ID


###################
# MCP TRANSPORT   #
###################

## Transport mode for the MCP server.
##   - "stdio"  — Single-client CLI mode (stdin/stdout). For Claude Desktop, VS Code, etc.
##   - "http"   — Multi-client HTTP mode. Standard for network/Docker deployments.
##   - "https"  — Multi-client HTTPS mode with TLS termination.
## Default: "stdio"
MCP_TRANSPORT=stdio

## Port the HTTP/HTTPS server listens on.
## Default: 8000
MCP_PORT=8000

## Host/IP address to bind the server to.
## Use "0.0.0.0" to accept connections from all interfaces (containers, remote).
## Use "127.0.0.1" to only accept local connections.
## Default: "127.0.0.1"
MCP_BIND_HOST=127.0.0.1

## Enable the legacy SSE transport (MCP protocol version 2024-11-05).
## Only needed for backwards compatibility with older MCP clients that
## don't support Streamable HTTP (protocol 2025-03-26).
## Default: false
MCP_LEGACY_SSE_ENABLED=false

## Prefer JSON responses over SSE streams for simple request-response.
## Non-streaming responses return application/json instead of text/event-stream.
## Warning: JSON mode silently drops progress and logging notifications.
## Default: false
MCP_JSON_RESPONSE=false


#########
# TLS   #
#########

## TLS configuration (required when MCP_TRANSPORT=https).
## Certificate files are read from the filesystem at server startup.

## Path to the TLS certificate file (PEM format).
## Required when MCP_TRANSPORT=https.
MCP_TLS_CERT_PATH=/certs/server.crt

## Path to the TLS private key file (PEM format).
## Required when MCP_TRANSPORT=https.
MCP_TLS_KEY_PATH=/certs/server.key

## Path to the CA certificate file (PEM format).
## Optional — use for custom CA chains or mutual TLS.
MCP_TLS_CA_PATH=/certs/ca.crt


##############
# SECURITY   #
##############

## Maximum requests allowed per rate limit window.
## Applies to the /mcp endpoint only (health/metrics are not rate-limited).
## Default: 1000
MCP_RATE_LIMIT_MAX=1000

## Rate limit window duration.
## Accepts human-readable durations (e.g. "15m", "1h") or plain millisecond counts.
## Default: "15m" (900000ms)
MCP_RATE_LIMIT_WINDOW_MS=15m

## Trust proxy setting for Express.
## Required when running behind a reverse proxy (nginx, Traefik, cloud LB)
## to correctly resolve client IPs from X-Forwarded-For headers.
## Values: hop count (1, 2), keyword ("loopback"), IP/CIDR, or comma-separated.
## Optional, no default (trust proxy disabled).
MCP_TRUST_PROXY=loopback

## Maximum request body size for the JSON body parser.
## Accepts Express size strings (e.g. "500kb", "1mb", "2mb").
## Default: "1mb"
MCP_BODY_SIZE_LIMIT=1mb

## Allowed hosts for DNS rebinding protection (comma-separated).
## When set, requests with a Host header not in this list are rejected (403).
## Important for servers exposed to the network.
## Optional, no default (all hosts allowed).
# MCP_ALLOWED_HOSTS=

## CORS allowed origins (comma-separated).
## When set, the CORS middleware allows requests from the listed origins.
## When omitted, CORS is completely disabled (no Access-Control-* headers).
## Use "*" to allow all origins (not recommended for production).
## Optional, no default (CORS disabled).
MCP_CORS_ORIGIN=*

## Allow credentials (cookies, Authorization headers) in CORS requests.
## Only effective when MCP_CORS_ORIGIN is set. Cannot be used with "*".
## Default: false
MCP_CORS_CREDENTIALS=false

## Enable HTTP Strict Transport Security (HSTS) header via Helmet.
## Sets Strict-Transport-Security: max-age=15552000; includeSubDomains (180 days).
## Only enable when the server is exclusively accessed over HTTPS.
## Default: false
MCP_HELMET_HSTS=false

## Content Security Policy (CSP) configuration via Helmet.
##   - Omit: Helmet default CSP applies (restrictive, suitable for API servers)
##   - "false": Disable CSP entirely
##   - Custom: CSP directives (e.g. "default-src 'self'; script-src 'none'")
## Optional, no default (Helmet default CSP).
MCP_HELMET_CSP=default-src 'self'

## X-Frame-Options header value via Helmet.
##   - "DENY": Never allow framing (most secure, recommended)
##   - "SAMEORIGIN": Allow framing from same origin
##   - "false": Disable X-Frame-Options header
## Default: "DENY"
MCP_HELMET_FRAME_OPTIONS=DENY


##############
# SESSIONS   #
##############

## Maximum total concurrent sessions across all transports.
## Once reached, new connections are rejected.
## Default: 200
MCP_MAX_SESSIONS=200

## Maximum concurrent Streamable HTTP sessions (must be ≤ max_sessions).
## Default: 100
MCP_MAX_STREAMABLE_HTTP_SESSIONS=100

## Maximum concurrent SSE sessions — legacy transport (must be ≤ max_sessions).
## Default: 50
MCP_MAX_SSE_SESSIONS=50


#############
# LOGGING   #
#############

## Log level. Messages below this level are suppressed.
## Values: "error", "warn", "info", "debug", "trace"
## Default: "info"
LOG_LEVEL=info

## Log output format.
##   - "text": Human-readable for development
##   - "json": Structured JSON (ECS-compatible) for log aggregation
## Default: "text"
LOG_FORMAT=text

## Include RFC 3339 timestamps in text log output.
## No effect in JSON mode (timestamps always included).
## Default: false
LOG_TIMESTAMP=false

## Include component name (e.g. [server-runtime]) in text log output.
## Useful for debugging which component generated a log line.
## Default: false
LOG_COMPONENT=false

## Directory for log file output.
## When set, logs are written to files in addition to console output.
## Optional, no default (file logging disabled).
# LOG_DIR=/var/log/komodo-mcp

## Maximum size of a single log file before rotation.
## Accepts human-readable sizes ("10mb", "500kb", "1gb").
## Default: "10mb"
LOG_MAX_FILE_SIZE=10mb

## Maximum number of rotated log files to keep.
## Default: 3
LOG_MAX_FILES=3

## Log file retention in days. Files older than this are deleted.
## Set to 0 to disable time-based retention.
## Default: 0 (disabled)
LOG_RETENTION_DAYS=0


###############
# TELEMETRY   #
###############

## OpenTelemetry distributed tracing and metrics.
## When enabled, the server exports traces and metrics via OTLP, Prometheus, or console.

## Master toggle for all OpenTelemetry features.
## When false, no OTEL packages are loaded (zero overhead).
## Default: false
OTEL_ENABLED=false

## OTEL service name. Defaults to the server name ("komodo-mcp-server").
## Override for deployment-specific naming (e.g. "komodo-mcp-prod").
## Optional, defaults to server name.
# OTEL_SERVICE_NAME=komodo-mcp-server

## OTLP exporter endpoint URL.
## Used by both trace and metric OTLP exporters.
## Examples:
##   - Jaeger:                  http://jaeger:4318
##   - Grafana Tempo:           http://tempo:4318
##   - OpenTelemetry Collector: http://otel-collector:4318
## Optional, no default.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

## Trace exporter selection.
## Values: "otlp", "console", "none"
## Default: "none"
OTEL_TRACES_EXPORTER=none

## Log exporter selection.
## The framework has its own logging system, so OTEL log export is
## disabled by default to prevent unwanted OTLP connections.
## Values: "otlp", "console", "none"
## Default: "none"
OTEL_LOGS_EXPORTER=none

## SDK diagnostic log level for debugging OTEL internals.
## Values: "none", "error", "warn", "info", "debug", "verbose", "all"
## Optional, default: "none".
OTEL_LOG_LEVEL=none

## Periodic metric export interval in milliseconds.
## How often metrics are pushed to the OTLP endpoint.
## Optional, no default (SDK default applies).
OTEL_METRIC_EXPORT_INTERVAL=60000

## Metric exporters to activate (comma-separated).
##   - "otlp":        Push metrics to OTLP endpoint
##   - "prometheus":   Scrape endpoint at /metrics
##   - "console":     Log metrics to console (debugging)
##   - "none":        Disable all metric export
## Default: "prometheus"
OTEL_METRICS_EXPORTER=prometheus


############
# DOCKER   #
############

## Timezone
## Sets the timezone of the server for timestamps in logs and telemetry
## Default: UTC
## Note: RFC 3339 format (e.g., UTC, Europe/Berlin, America/New_York)
TZ=UTC
